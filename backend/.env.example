NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
MONGO_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/realmedicinedb?ssl=true&replicaSet=atlas-cluster-shard-0&authSource=admin&retryWrites=true&w=majority
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_RETRY_DELAY_MS=5000
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
# Legacy fallback supported by the codebase, but prefer JWT_ACCESS_SECRET for new environments.
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=30
ALLOW_PUBLIC_REGISTER=false
# Comma-separated allowlist for web dashboards, admin panels, or API tools.
# For local development, include only the origins you actually use.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=debug
# Optional. Relative paths resolve from the repository root.
UPLOAD_ROOT=uploads
UPLOAD_MAX_SIZE_BYTES=5242880
# Optional public prefix for download links when the API is deployed behind a public host.
UPLOAD_PUBLIC_BASE_URL=https://api.your-domain.com/api/v1/uploads
