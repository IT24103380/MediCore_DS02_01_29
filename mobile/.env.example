EXPO_PUBLIC_APP_ENV=development
# Set either one shared API base URL or the per-environment values below.
EXPO_PUBLIC_API_BASE_URL=
# Local development examples:
# - Android emulator: http://10.0.2.2:5001/api/v1
# - iOS simulator on macOS / local web: http://127.0.0.1:5001/api/v1
# - Physical device on the same network: http://YOUR-LAN-IP:5001/api/v1
EXPO_PUBLIC_API_BASE_URL_DEVELOPMENT=http://10.0.2.2:5001/api/v1
EXPO_PUBLIC_API_BASE_URL_STAGING=https://staging-api.your-domain.com/api/v1
EXPO_PUBLIC_API_BASE_URL_PRODUCTION=https://api.your-domain.com/api/v1
